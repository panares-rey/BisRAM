@* Cart/Index.cshtml — The SHOPPING CART page.
   Shows the current user's cart items, quantities, and total price.
   Lets users update quantities or remove items before checking out. *@
﻿@model List<BisRAM.Models.CartItem>
@{
    ViewBag.Title = "My Cart";
    decimal total = Model.Sum(i => (i.Product?.Price ?? 0) * i.Quantity);
}

<div class="container">
    <h2 class="page-title"><i class="fas fa-shopping-cart"></i> My Cart</h2>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fas fa-shopping-cart"></i>
            <h3>Your cart is empty</h3>
            <a href="/Products" class="btn-primary">Start Shopping</a>
        </div>
    }
    else
    {
        <div class="cart-layout">
            <div class="cart-items">
                <div class="cart-header">
                    <span>Product</span>
                    <span>Price</span>
                    <span>Qty</span>
                    <span>Subtotal</span>
                    <span></span>
                </div>

                @foreach (var item in Model)
                {
                    <div class="cart-row">
                        <div class="cart-product">
                            <div class="cart-img"><i class="fas fa-microchip"></i></div>
                            <div>
                                <a href="/Products/Details/@item.ProductId">@item.Product?.Name</a>
                                <p>@item.Product?.Brand — @item.Product?.Category</p>
                            </div>
                        </div>
                        <span class="cart-price">₱@item.Product?.Price.ToString("N2")</span>
                        <form asp-action="UpdateQuantity" method="post" class="qty-form">
                            <input type="hidden" name="cartItemId" value="@item.Id" />
                            <div class="qty-selector small">
                                <button type="submit" name="quantity" value="@(item.Quantity - 1)">-</button>
                                <span>@item.Quantity</span>
                                <button type="submit" name="quantity" value="@(item.Quantity + 1)">+</button>
                            </div>
                        </form>
                        <span class="cart-subtotal">₱@(((item.Product?.Price ?? 0) * item.Quantity).ToString("N2"))</span>
                        <form asp-action="Remove" method="post">
                            <input type="hidden" name="cartItemId" value="@item.Id" />
                            <button type="submit" class="btn-remove"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                }
            </div>

            <div class="cart-summary">
                <h3>Order Summary</h3>
                <div class="summary-row">
                    <span>Items (@Model.Sum(i => i.Quantity))</span>
                    <span>₱@total.ToString("N2")</span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                    <span>@(total >= 5000 ? "FREE" : "₱150.00")</span>
                </div>
                <div class="summary-total">
                    <span>Total</span>
                    <span>₱@((total + (total >= 5000 ? 0 : 150)).ToString("N2"))</span>
                </div>
                <a href="/Cart/Checkout" class="btn-primary btn-block">
                    <i class="fas fa-lock"></i> Proceed to Checkout
                </a>
                <a href="/Products" class="btn-outline btn-block">
                    <i class="fas fa-arrow-left"></i> Continue Shopping
                </a>
            </div>
        </div>
    }
</div>
