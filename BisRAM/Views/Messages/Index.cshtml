@* Messages/Index.cshtml — The MESSAGES INBOX.
   Lists all conversations the logged-in user has, with the most recent message shown.
   Bound to List<Conversation> from MessagesController.Index(). *@
@model List<BisRAM.Models.Conversation>
@{ ViewBag.Title = "Messages"; }
<div class="container" style="padding:32px 24px">
    <h2 class="page-title animate-up"><i class="fas fa-comment-dots"></i> Messages</h2>
    @if (!Model.Any())
    {
        <div class="empty-state animate-up"><i class="fas fa-comment-slash"></i><h3>No messages yet</h3><p>Browse the <a href="/Marketplace">Marketplace</a> and message a seller!</p></div>
    }
    else
    {
        <div class="conversations-list animate-up">
            @foreach (var c in Model.OrderByDescending(x => x.LastMessageAt))
            {
                <a href="/Messages/Chat?userId=@c.OtherUserId" class="convo-card @(c.UnreadCount>0?"unread":"")">
                    <img src="@c.OtherUserAvatar" class="convo-avatar" onerror="this.src='/images/avatars/default.svg'" />
                    <div class="convo-info">
                        <div class="convo-header">
                            <strong>@c.OtherUserName</strong>
                            <span class="convo-time">@c.LastMessageAt.ToString("MMM dd")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(c.ListingTitle))
                        { <p class="convo-listing"><i class="fas fa-tag"></i> @c.ListingTitle</p> }
                        <p class="convo-preview">@c.LastMessage</p>
                    </div>
                    @if (c.UnreadCount > 0)
                    { <span class="unread-badge">@c.UnreadCount</span> }
                </a>
            }
        </div>
    }
</div>
