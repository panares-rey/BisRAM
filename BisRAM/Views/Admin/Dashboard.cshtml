@* Admin/Dashboard.cshtml — THE ADMIN DASHBOARD.
   Shows site stats: total users, orders, revenue, and recent activity.
   Only accessible to users with Role = 'Admin'. *@
@model BisRAM.Models.AdminDashboardViewModel
@{ ViewBag.Title = "Admin Dashboard"; }
<div class="admin-layout">
    @await Html.PartialAsync("_AdminSidebar")
    <div class="admin-main">
        <div class="admin-header animate-down">
            <h2><i class="fas fa-tachometer-alt"></i> Dashboard</h2>
            <span>Welcome, @Context.Session.GetString("UserName")</span>
        </div>
        <div class="stats-grid">
            <div class="stat-card blue animate-up"><div class="stat-icon"><i class="fas fa-box"></i></div><div class="stat-info"><span class="stat-val">@Model.TotalProducts</span><span class="stat-label">Products</span></div></div>
            <div class="stat-card green animate-up"><div class="stat-icon"><i class="fas fa-shopping-bag"></i></div><div class="stat-info"><span class="stat-val">@Model.TotalOrders</span><span class="stat-label">Orders</span></div></div>
            <div class="stat-card orange animate-up"><div class="stat-icon"><i class="fas fa-users"></i></div><div class="stat-info"><span class="stat-val">@Model.TotalUsers</span><span class="stat-label">Customers</span></div></div>
            <div class="stat-card purple animate-up"><div class="stat-icon"><i class="fas fa-peso-sign"></i></div><div class="stat-info"><span class="stat-val">₱@Model.TotalRevenue.ToString("N0")</span><span class="stat-label">Revenue</span></div></div>
            <div class="stat-card teal animate-up"><div class="stat-icon"><i class="fas fa-handshake"></i></div><div class="stat-info"><span class="stat-val">@Model.TotalListings</span><span class="stat-label">Marketplace</span></div></div>
        </div>
        <div class="admin-panels">
            <div class="admin-panel animate-left">
                <div class="panel-header"><h3><i class="fas fa-clock"></i> Recent Orders</h3><a href="/Admin/Orders">View All</a></div>
                <table class="admin-table"><thead><tr><th>#</th><th>Customer</th><th>Total</th><th>Status</th><th>Date</th></tr></thead>
                <tbody>
                @foreach (var o in Model.RecentOrders)
                {
                    <tr><td>#@o.Id</td><td>@o.FullName</td><td>₱@o.Total.ToString("N2")</td><td><span class="status-badge @o.Status.ToLower()">@o.Status</span></td><td>@o.CreatedAt.ToString("MMM dd")</td></tr>
                }
                </tbody></table>
            </div>
            <div class="admin-panel animate-right">
                <div class="panel-header"><h3><i class="fas fa-exclamation-triangle"></i> Low Stock</h3><a href="/Admin/Products">Manage</a></div>
                @if (!Model.LowStockProducts.Any()) { <p class="no-data">All products well stocked!</p> }
                else {
                    <table class="admin-table"><thead><tr><th>Product</th><th>Category</th><th>Stock</th></tr></thead>
                    <tbody>
                    @foreach (var p in Model.LowStockProducts)
                    { <tr><td>@p.Name</td><td>@p.Category</td><td><span class="@(p.Stock==0?"badge-danger":"badge-warn")">@p.Stock</span></td></tr> }
                    </tbody></table>
                }
            </div>
        </div>
    </div>
</div>
