@model List<BisRAM.Models.Order>
@{
    ViewBag.Title = "Manage Orders";
}

<div class="admin-layout">
    @await Html.PartialAsync("_AdminSidebar")
    <div class="admin-main">
        <div class="admin-header">
            <h2><i class="fas fa-shopping-bag"></i> Orders</h2>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
        }

        <div class="admin-panel">
            <table class="admin-table full">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Customer</th>
                        <th>Phone</th>
                        <th>Payment</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td><strong>#@o.Id</strong></td>
                            <td>@o.FullName</td>
                            <td>@o.Phone</td>
                            <td>@o.PaymentMethod</td>
                            <td>₱@o.Total.ToString("N2")</td>
                            <td><span class="status-badge @o.Status.ToLower()">@o.Status</span></td>
                            <td>@o.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a href="/Admin/OrderDetails/@o.Id" class="btn-sm btn-edit">
                                    <i class="fas fa-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
