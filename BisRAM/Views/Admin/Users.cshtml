@model List<BisRAM.Models.User>
@{ ViewBag.Title = "Customers"; }
<div class="admin-layout">
    @await Html.PartialAsync("_AdminSidebar")
    <div class="admin-main">
        <div class="admin-header animate-down"><h2><i class="fas fa-users"></i> Customers</h2><span>@Model.Count(u=>u.Role=="Customer") customers</span></div>
        @if(TempData["Success"]!=null){<div class="flash flash-success">@TempData["Success"]</div>}
        <div class="admin-panel animate-up">
            <table class="admin-table full">
                <thead><tr><th>#</th><th>Avatar</th><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Status</th><th>Joined</th></tr></thead>
                <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td><img src="@(u.AvatarUrl??"/images/avatars/default.svg")" style="width:32px;height:32px;border-radius:50%;object-fit:cover" onerror="this.src='/images/avatars/default.svg'" /></td>
                        <td><strong>@u.FullName</strong></td>
                        <td>@u.Email</td>
                        <td>@(string.IsNullOrEmpty(u.Phone)?"—":u.Phone)</td>
                        <td><span class="role-badge @u.Role.ToLower()">@u.Role</span></td>
                        <td><span class="@(u.IsActive?"badge-ok":"badge-danger")">@(u.IsActive?"Active":"Suspended")</span></td>
                        <td>@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
