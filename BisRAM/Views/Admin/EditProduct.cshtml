@model BisRAM.Models.Product
@{
    ViewBag.Title = "Edit Product";
}

<div class="admin-layout">
    @await Html.PartialAsync("_AdminSidebar")
    <div class="admin-main">
        <div class="admin-header">
            <h2><i class="fas fa-edit"></i> Edit Product</h2>
            <a href="/Admin/Products" class="btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
        }

        <div class="admin-panel form-panel">
            <form asp-action="EditProduct" method="post">
                <input type="hidden" name="Id" value="@Model.Id" />
                <div class="form-row-2">
                    <div class="form-group">
                        <label>Product Name *</label>
                        <input type="text" name="Name" value="@Model.Name" required />
                    </div>
                    <div class="form-group">
                        <label>Brand *</label>
                        <input type="text" name="Brand" value="@Model.Brand" required />
                    </div>
                </div>
                <div class="form-row-2">
                    <div class="form-group">
                        <label>Category *</label>
                        <select name="Category" required>
                            @foreach (var c in new[]{"CPU","GPU","RAM","Storage","Motherboard","PSU","Case","Cooling","Peripherals","Other"})
                            {
                                if (Model.Category == c)
                                {
                                    <option value="@c" selected>@c</option>
                                }
                                else
                                {
                                    <option value="@c">@c</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Price (₱) *</label>
                        <input type="number" name="Price" value="@Model.Price" min="0" step="0.01" required />
                    </div>
                </div>
                <div class="form-row-2">
                    <div class="form-group">
                        <label>Stock *</label>
                        <input type="number" name="Stock" value="@Model.Stock" min="0" required />
                    </div>
                    <div class="form-group">
                        <label>Image URL</label>
                        <input type="text" name="ImageUrl" value="@Model.ImageUrl" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="Description" rows="4">@Model.Description</textarea>
                </div>
                <div class="form-group">
                    <label class="check-label">
                        @if (Model.IsActive)
                        {
                            <input type="checkbox" name="IsActive" value="true" checked />
                        }
                        else
                        {
                            <input type="checkbox" name="IsActive" value="true" />
                        }
                        Active (visible in store)
                    </label>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Update Product</button>
                    <a href="/Admin/Products" class="btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
