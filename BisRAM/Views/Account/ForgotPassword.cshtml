@{ ViewBag.Title = "Forgot Password"; }
<div class="auth-page">
    <div class="auth-box animate-up">
        <div class="auth-logo"><i class="fas fa-microchip"></i><h2>BisRAM</h2></div>
        <h3><i class="fas fa-key"></i> Reset Password</h3>
        <p class="auth-sub">Enter your email to get a reset link.</p>
        @if (ViewBag.Error != null) { <div class="flash flash-error">@ViewBag.Error</div> }
        <form method="post">
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="email" placeholder="you@email.com" required />
            </div>
            <button type="submit" class="btn-primary btn-block"><i class="fas fa-paper-plane"></i> Send Reset Link</button>
        </form>
        <div class="auth-footer"><a href="/Account/Login"><i class="fas fa-arrow-left"></i> Back to Login</a></div>
    </div>
</div>
