@{ ViewBag.Title = "Reset Password"; }
<div class="auth-page">
    <div class="auth-box animate-up">
        <div class="auth-logo"><i class="fas fa-microchip"></i><h2>BisRAM</h2></div>
        <h3><i class="fas fa-lock"></i> New Password</h3>
        @if (ViewBag.Error != null) { <div class="flash flash-error">@ViewBag.Error</div> }
        <form method="post">
            <input type="hidden" name="token" value="@ViewBag.Token" />
            <div class="form-group">
                <label>New Password</label>
                <div class="input-eye">
                    <input type="password" name="newPassword" id="p1" placeholder="Min 8 chars, uppercase, number, symbol" required />
                    <button type="button" onclick="togglePwd()"><i class="fas fa-eye" id="e1"></i></button>
                </div>
            </div>
            <div class="form-group">
                <label>Confirm Password</label>
                <input type="password" name="confirmPassword" placeholder="Repeat password" required />
            </div>
            <div class="password-rules">
                <p><i class="fas fa-info-circle"></i> Password must have:</p>
                <ul>
                    <li id="r1"><i class="fas fa-circle"></i> At least 8 characters</li>
                    <li id="r2"><i class="fas fa-circle"></i> One uppercase letter</li>
                    <li id="r3"><i class="fas fa-circle"></i> One number</li>
                    <li id="r4"><i class="fas fa-circle"></i> One special character (!#$%)</li>
                </ul>
            </div>
            <button type="submit" class="btn-primary btn-block"><i class="fas fa-save"></i> Reset Password</button>
        </form>
        <div class="auth-footer"><a href="/Account/Login"><i class="fas fa-arrow-left"></i> Back to Login</a></div>
    </div>
</div>
<script>
function togglePwd() {
    var i = document.getElementById('p1');
    var ic = document.getElementById('e1');
    if (i.type === 'password') { i.type = 'text'; ic.className = 'fas fa-eye-slash'; }
    else { i.type = 'password'; ic.className = 'fas fa-eye'; }
}
document.getElementById('p1').addEventListener('input', function () {
    var v = this.value;
    document.getElementById('r1').className = v.length >= 8 ? 'met' : '';
    document.getElementById('r2').className = /[A-Z]/.test(v) ? 'met' : '';
    document.getElementById('r3').className = /[0-9]/.test(v) ? 'met' : '';
    document.getElementById('r4').className = /[!#$%^&*]/.test(v) ? 'met' : '';
});
</script>
